# ZenDBX Production Configuration
# Domain: zendbx.in

# Application
APP_NAME=ZenDBX
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# Database - CHANGE THESE IN PRODUCTION
DATABASE_URL=postgresql://zendbx_user:CHANGE_THIS_PASSWORD@localhost:5432/zendbx_main
DATABASE_POOL_SIZE=50
DATABASE_MAX_OVERFLOW=20

# Redis (for quota tracking and caching)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# Security - GENERATE NEW SECRET KEY
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_THIS_TO_RANDOM_SECRET_KEY_IN_PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# OpenRouter AI Configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_AI_MODEL=openai/gpt-4-turbo-preview

# CORS - Production domains
ALLOWED_ORIGINS=["https://devapp.zendbx.in","https://zendbx.in","https://www.zendbx.in","https://api.zendbx.in"]

# Domain Configuration for Wildcard Subdomains
BASE_DOMAIN=zendbx.in
ENABLE_SUBDOMAIN_ROUTING=true

# File Upload
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=.csv,.json,.xlsx
UPLOAD_DIR=./uploads

# Storage (S3-compatible) - Configure for production
STORAGE_TYPE=local
S3_BUCKET_NAME=zendbx-storage
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT_URL=

# Query Settings
QUERY_TIMEOUT_SECONDS=30
MAX_ROWS_RETURNED=10000
ENABLE_QUERY_CACHE=True
CACHE_TTL_SECONDS=600

# Rate Limiting - Production limits
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000

# WebSocket & Realtime
WEBSOCKET_SERVER_URL=https://ws.zendbx.in
ENABLE_REALTIME=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_DEFAULT_SCHEDULE=daily
BACKUP_DEFAULT_TIME=02:00
BACKUP_DEFAULT_DAY=0
BACKUP_STAGGER_MAX_MINUTES=30
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_RETRIES=3

# OAuth (Configure with your OAuth apps)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email (Configure for production notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@zendbx.in
SMTP_PASSWORD=your-app-password

# Monitoring & Logging
LOG_LEVEL=INFO
SENTRY_DSN=your-sentry-dsn-here

# SSL/HTTPS
FORCE_HTTPS=true
SECURE_COOKIES=true

# Application
APP_NAME=Nexora AI
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5433/nexora_main
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis (for quota tracking and caching)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# OpenRouter AI Configuration
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_AI_MODEL=openai/gpt-4-turbo-preview
# Available models: openai/gpt-4-turbo-preview, anthropic/claude-3-opus, meta-llama/llama-3-70b-instruct

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Domain Configuration for Wildcard Subdomains
BASE_DOMAIN=localhost
ENABLE_SUBDOMAIN_ROUTING=true

# File Upload
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=.csv,.json,.xlsx
UPLOAD_DIR=./uploads

# Storage (S3-compatible)
STORAGE_TYPE=local  # local or s3
S3_BUCKET_NAME=nexora-storage
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT_URL=  # Leave empty for AWS, or use MinIO endpoint

# Redis (for caching and background jobs)
REDIS_URL=redis://localhost:6379/0

# Query Settings
QUERY_TIMEOUT_SECONDS=10
MAX_ROWS_RETURNED=1000
ENABLE_QUERY_CACHE=True
CACHE_TTL_SECONDS=300

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# WebSocket & Realtime
WEBSOCKET_SERVER_URL=http://localhost:3002
ENABLE_REALTIME=true

# Backup Scheduler Configuration
BACKUP_ENABLED=true
BACKUP_DEFAULT_SCHEDULE=weekly
BACKUP_DEFAULT_TIME=00:00
BACKUP_DEFAULT_DAY=0
BACKUP_STAGGER_MAX_MINUTES=30
BACKUP_RETENTION_DAYS=30
BACKUP_MAX_RETRIES=3

# OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
